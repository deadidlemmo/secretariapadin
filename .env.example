# Flask/session security.
# Generate a strong value before deploying.
FLASK_SECRET_KEY=change-me-generate-a-long-random-secret

# Token used on the login screen.
ACCESS_TOKEN=change-me

# Maximum request/upload size in megabytes.
MAX_CONTENT_LENGTH_MB=50

# Optional: enable EJA processing in supported reports.
ENABLE_EJA=0

# Optional school-year values used in generated documents.
SCHOOL_YEAR=2026
CONCLUSAO_5ANO_DATE_TEXT=Praia Grande, 22 de dezembro de 2026
INFORMATIVO_WEEKDAY_DUE=4

# Optional: set to 1 only when served exclusively over HTTPS.
SESSION_COOKIE_SECURE=0
